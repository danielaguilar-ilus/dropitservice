# ─────────────────────────────────────────────────────────────────────────────
# DROPIT — Variables de entorno
# Copia este archivo a `.env` (NO se commitea) y completa los valores.
# En Railway: configúralas en el servicio @dropit/api → Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App / runtime ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# URL pública del frontend (usada en links de confirmación y CORS en producción)
PUBLIC_URL=http://localhost:5173

# ─── Frontend (Vite — se inyectan en build, prefijo VITE_) ───────────────────
# En producción detrás del mismo dominio, usar ruta relativa /api.
# En local apuntando a la API en :4000, usar http://localhost:4000/api
VITE_API_URL=/api

# ─── Base de datos (fuente de verdad en producción) ──────────────────────────
# Si está vacía, la app cae a db.json local (solo para desarrollo/seed).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dropit

# ─── Correo: Resend (recomendado — HTTPS, funciona en Railway) ───────────────
# Regístrate gratis en https://resend.com (sin tarjeta). 3000 emails/mes.
RESEND_API_KEY=
# Remitente verificado. Si vacío usa onboarding@resend.dev (solo pruebas).
RESEND_FROM=DropIt Service <noreply@tudominio.cl>
# Bandeja del operador que recibe avisos internos (si vacío usa SMTP_USER).
OPERATOR_EMAIL=

# ─── Correo: SMTP (fallback — Railway suele bloquear el puerto 587) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DropIt Service

# ─── Seguridad ───────────────────────────────────────────────────────────────
# Token para endpoints /_admin/* y como llave de servicio en /mail y /whatsapp.
# Genera uno largo y aleatorio. SIN default — si falta, /_admin/* responde 503.
ADMIN_TOKEN=

# Usuario administrador semilla (SOLO fallback local sin Postgres).
# En producción la fuente de verdad es Postgres (seed vía /_admin/seed-users).
SEED_ADMIN_EMAIL=admin@dropit.local
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_NAME=Administrador Dropit

# ─── Mapas ───────────────────────────────────────────────────────────────────
# Backend (geocoding/directions opcional)
GOOGLE_MAPS_API_KEY=
# Frontend (autocomplete de direcciones). Requiere billing en Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=
# Alternativa sin tarjeta para autocomplete (250k/mes): https://platform.here.com
VITE_HERE_API_KEY=

# ─── Cloudinary (almacenamiento de fotos — opcional pero recomendado) ────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Twilio WhatsApp (opcional) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
